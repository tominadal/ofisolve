# === Configuración General ===
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# === Base de Datos PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://ofisolve:ofisolve_dev@localhost:5432/ofisolve_db

# === LLM (Gemini) ===
# Conseguir API key GRATIS en: https://aistudio.google.com/apikey
GOOGLE_API_KEY=tu-api-key-de-gemini-aqui
LLM_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=4096
EMBEDDING_MODEL=models/text-embedding-004

# === ChromaDB (Vector DB local, sin Docker) ===
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=normativa_notarial

# === Seguridad ===
SECRET_KEY=cambiar-en-produccion-generar-con-openssl
CORS_ORIGINS=["http://localhost:3000"]
